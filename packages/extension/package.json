{
  "name": "shapeitup-vscode",
  "displayName": "ShapeItUp",
  "description": "Scripted CAD for VS Code — write TypeScript, see 3D, export STEP/STL. AI-powered with Claude Code MCP integration.",
  "version": "1.3.0",
  "publisher": "shapeitup",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/asbis/ShapeItUp"
  },
  "homepage": "https://github.com/asbis/ShapeItUp#readme",
  "bugs": {
    "url": "https://github.com/asbis/ShapeItUp/issues"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "cad",
    "3d",
    "replicad",
    "opencascade",
    "step",
    "stl",
    "parametric",
    "mechanical",
    "engineering",
    "ai",
    "mcp"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "workspaceContains:**/*.shape.ts"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shapeitup.preview",
        "title": "ShapeItUp: Preview Shape",
        "icon": "$(eye)"
      },
      {
        "command": "shapeitup.exportSTEP",
        "title": "ShapeItUp: Export as STEP"
      },
      {
        "command": "shapeitup.exportSTL",
        "title": "ShapeItUp: Export as STL"
      },
      {
        "command": "shapeitup.openInApp",
        "title": "ShapeItUp: Export and Open in…"
      },
      {
        "command": "shapeitup.rescanApps",
        "title": "ShapeItUp: Rescan installed 3D apps"
      },
      {
        "command": "shapeitup.resetLaunchPrefs",
        "title": "ShapeItUp: Reset launch preferences (single-window vs new)"
      },
      {
        "command": "shapeitup.newShape",
        "title": "ShapeItUp: New Shape File"
      },
      {
        "command": "shapeitup.setupProject",
        "title": "ShapeItUp: Setup Project (install replicad types)"
      },
      {
        "command": "shapeitup.installMcpServer",
        "title": "ShapeItUp: Install MCP Server…"
      },
      {
        "command": "shapeitup.uninstallMcpServer",
        "title": "ShapeItUp: Uninstall MCP Server…"
      }
    ],
    "walkthroughs": [
      {
        "id": "shapeitup.getStarted",
        "title": "Get started with ShapeItUp",
        "description": "Enable AI assistants (Claude Code, Cursor, Gemini) to use ShapeItUp.",
        "steps": [
          {
            "id": "installMcp",
            "title": "Install the MCP server for your AI client",
            "description": "Run [ShapeItUp: Install MCP Server…](command:shapeitup.installMcpServer) to register ShapeItUp with Claude Code, Cursor, Claude Desktop, or Gemini CLI. VS Code Copilot Agent Mode is registered automatically — no action needed.",
            "media": {
              "markdown": "media/walkthrough-mcp.md"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shapeitup-sidebar",
          "title": "ShapeItUp",
          "icon": "media/icon-sidebar.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "shapeitup-secondary",
          "title": "ShapeItUp",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "shapeitup-secondary": [
        {
          "type": "webview",
          "id": "shapeitup.viewer",
          "name": "3D Preview"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "shapeitup-mcp",
        "label": "ShapeItUp CAD"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "shapeitup.preview",
          "when": "resourceFilename =~ /\\.shape\\.ts$/",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "shapeitup.preview",
        "key": "ctrl+shift+v",
        "when": "resourceFilename =~ /\\.shape\\.ts$/"
      }
    ]
  },
  "dependencies": {
    "esbuild-wasm": "^0.28.0"
  },
  "devDependencies": {
    "@shapeitup/shared": "workspace:*",
    "@types/vscode": "^1.106.0"
  }
}
